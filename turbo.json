{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "ANTHROPIC_API_KEY",
        "FIRECRAWL_API_KEY",
        "INTERNAL_SERVICE_SECRET",
        "KINETIKS_ENCRYPTION_KEY",
        "NEXT_PUBLIC_APP_URL",
        "IDENTITY_API_URL",
        "GA4_CLIENT_ID",
        "GA4_CLIENT_SECRET",
        "GSC_CLIENT_ID",
        "GSC_CLIENT_SECRET",
        "STRIPE_SECRET_KEY",
        "HUBSPOT_CLIENT_ID",
        "HUBSPOT_CLIENT_SECRET",
        "GOOGLE_WORKSPACE_CLIENT_ID",
        "GOOGLE_WORKSPACE_CLIENT_SECRET",
        "MICROSOFT_365_CLIENT_ID",
        "MICROSOFT_365_CLIENT_SECRET",
        "RESEND_API_KEY",
        "SLACK_BOT_TOKEN",
        "SLACK_SIGNING_SECRET",
        "SLACK_APP_TOKEN",
        "SLACK_CLIENT_ID",
        "SLACK_CLIENT_SECRET",
        "PEOPLE_DATA_LABS_API_KEY",
        "POSTHOG_API_KEY",
        "SENTRY_DSN",
        "HARVEST_API_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
