# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Internal service auth (required - shared across all Kinetiks apps)
INTERNAL_SERVICE_SECRET=your-internal-secret

# Anthropic (required - powers email generation, research, classification)
ANTHROPIC_API_KEY=sk-ant-...

# People Data Labs (required - contact enrichment)
PDL_API_KEY=your-pdl-key

# Hunter.io (required - email finding)
HUNTER_API_KEY=your-hunter-key

# Resend (required - transactional email sending)
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# AWS SES (optional - bulk/sequence email sending, falls back to Resend)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SES_REGION=us-east-1
# AWS_SES_CONFIG_SET=harvest-tracking

# Kinetiks ID connection (required for Synapse integration)
KINETIKS_ID_API_URL=https://id.kinetiks.ai
NEXT_PUBLIC_ID_URL=https://id.kinetiks.ai

# App URL
NEXT_PUBLIC_APP_URL=https://hv.kinetiks.ai

# Cookie domain (optional - defaults to .kinetiks.ai for shared auth)
# NEXT_PUBLIC_COOKIE_DOMAIN=.kinetiks.ai

# Default sender (optional - used when no mailbox configured)
# DEFAULT_FROM_EMAIL=noreply@kinetiks.ai
