# DeskOf — environment variable reference
#
# Copy this file to .env.local and fill in real values for local
# development. Vercel deployments configure these in the dashboard.

# ---------------------------------------------------------------- #
# Supabase
# ---------------------------------------------------------------- #
# Public URL — visible to the browser, safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — also safe to expose; constrained by RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — NEVER expose to the browser. Edge functions,
# webhook receivers, and the dev seed route use this to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------------------------------------------------------------- #
# Kinetiks ID integration
# ---------------------------------------------------------------- #
# Domain used for the shared session cookie. Production uses
# .kinetiks.ai so id.kinetiks.ai and deskof.kinetiks.ai see the same
# session. Leave unset for localhost development.
# COOKIE_DOMAIN=.kinetiks.ai

# Public URL of the Kinetiks ID billing flow. The /upgrade page links here.
NEXT_PUBLIC_KINETIKS_BILLING_URL=https://id.kinetiks.ai/billing

# HMAC-SHA256 shared secret used to verify inbound webhooks from
# apps/id (e.g., the account-deletion webhook). MUST match the value
# stored on the corresponding apps/id outbound webhook row.
# If unset, the webhook receiver fails closed and rejects every
# request with 503 — that is intentional defense-in-depth.
KINETIKS_WEBHOOK_SECRET=replace-me-with-a-strong-shared-secret

# ---------------------------------------------------------------- #
# Reddit (Phase 1.4 follow-up — currently unused)
# ---------------------------------------------------------------- #
# These will be wired once Reddit Data API access is approved and
# the Reddit OAuth client lands. Leave unset until then.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_REDIRECT_URI=http://localhost:3005/api/auth/reddit/callback

# ---------------------------------------------------------------- #
# LLM providers (Phase 0 + Phases 3/4/6)
# ---------------------------------------------------------------- #
# These will be wired by Phase 3 (Lens) and Phase 6 (Pulse citation
# checks). Phase 2.5 doesn't call any LLMs at runtime.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# ---------------------------------------------------------------- #
# Dev only
# ---------------------------------------------------------------- #
# In production, the dev seed route at /api/dev/seed-fixtures refuses
# to run unless this is explicitly set to "true". In development
# (NODE_ENV !== "production") it runs by default.
# DESKOF_ALLOW_DEV_SEED=false

# Bumped on each deploy. Used as the analytics user_id hash salt and
# surfaced in the /api/health response.
NEXT_PUBLIC_APP_VERSION=0.2.5-dev
